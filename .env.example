# Copy this file to .env and fill in your Supabase project credentials.
# Find these in: Supabase dashboard → Project Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Stripe — price IDs from your Stripe Dashboard → Products
# Phase 4: used by the UpgradeModal to initiate checkout
VITE_STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxx
VITE_STRIPE_TEAM_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxx
