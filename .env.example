# Copy this file to .env and fill in your Supabase project credentials.
# Find these in: Supabase dashboard → Project Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Stripe — find these in your Stripe Dashboard
# Publishable key: Developers → API keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxx

# Price ID: Products → your product → pricing
VITE_STRIPE_PREMIUM_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxx
